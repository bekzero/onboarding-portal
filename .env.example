# Auth.js / KZero OIDC
AUTH_SECRET=replace-with-a-random-secret
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=your-kzero-oidc-client-id
AUTH_KEYCLOAK_SECRET=your-kzero-oidc-client-secret
# Issuer pattern: https://ca.auth.kzero.com/realms/<ExactTenantName>
# Tenant / realm names are case-sensitive and must match KZero exactly.
AUTH_KEYCLOAK_ISSUER=https://ca.auth.kzero.com/realms/ABCMSP

# KZero tenant discovery helpers
KZERO_OIDC_BASE_URL=https://ca.auth.kzero.com
KZERO_OIDC_REDIRECT_URI=https://onboarding-portal20.vercel.app/api/oidc/callback
KZERO_TEST_TENANT=abcmsp

# Temporary admin access
ADMIN_ACCESS_CODE=change-me
ADMIN_SESSION_COOKIE=kzero_admin_session
